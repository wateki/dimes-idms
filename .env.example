# Copy to `.env` and fill in. Vite exposes only variables prefixed with VITE_.

# Canonical URL for SEO (sitemap, Open Graph). Example: https://idms.dimes.africa
VITE_SITE_URL=

# Optional: hero "Explore Platform" one-click demo sign-in (both required).
# If either is missing, the hero shows "Watch Demo" (YouTube) instead.
VITE_DEMO_PLATFORM_EMAIL=
VITE_DEMO_PLATFORM_PASSWORD=
